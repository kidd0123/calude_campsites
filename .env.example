# Copy to .env and source it: `set -a; source .env; set +a`

# RIDB / Recreation.gov — required for facility catalog AND camply availability
# Free: https://ridb.recreation.gov/  → Sign in → Account → API Key
RIDB_API_KEY=

# Reddit (PRAW) — required for ingest_reddit.py
# Free: https://www.reddit.com/prefs/apps → "Create app" → "script" type
# - name: camp-finder
# - redirect uri: http://localhost
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=camp-finder/0.1 (by u/yourusername)
